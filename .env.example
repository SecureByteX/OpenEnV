# Copy to .env and fill in values:  cp .env.example .env

# LLM inference (MANDATORY for inference.py)
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o

# Environment server URL
API_BASE_URL=http://localhost:7860

# HuggingFace token (only needed for private Spaces)
HF_TOKEN=hf_...

# Docker image name (used by validate-submission.sh)
LOCAL_IMAGE_NAME=code-review-env
